---
// Self-hosted fonts (bundled + fingerprinted at build) — no runtime dependency
// on Google Fonts. Londrina Solid (headings) only needs 400/900; Libre Franklin
// (body) ships as a single variable file covering every weight in use.
import "@fontsource/londrina-solid/latin-400.css";
import "@fontsource/londrina-solid/latin-900.css";
import "@fontsource-variable/libre-franklin/wght.css";
import "../styles/global.css";
import FollowUs from "../components/FollowUs.astro";
import HostClosedPopover from "../components/HostClosedPopover.astro";
import Navbar from "../components/Navbar.astro";
import PerformClosedPopover from "../components/PerformClosedPopover.astro";
import VolunteerPopover from "../components/VolunteerPopover.astro";

interface Props {
    title?: string;
    description?: string;
}

const { title = "Tacoma Porchfest", description } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/PF-Icon.svg" />
        <meta name="viewport" content="width=device-width, viewport-fit=cover" />
        <meta name="generator" content={Astro.generator} />
        {description && <meta name="description" content={description} />}
        <title>{title}</title>
    </head>
    <body class="font-sans bg-pf-cream">
        <Navbar />
        <div class="mt-12 md:mt-14">
            <slot />
        </div>
        <FollowUs />
        <PerformClosedPopover />
        <HostClosedPopover />
        <VolunteerPopover />
    </body>
</html>
