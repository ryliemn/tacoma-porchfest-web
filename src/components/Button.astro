---
interface Props {
    href: string;
    text: string;
    variant?: "default" | "inverted";
    external?: boolean;
    class?: string;
}

const { href, text, variant = "default", external = false, class: className = "" } = Astro.props;

const variantStyles = {
    default: "bg-pf-red text-pf-cream",
    inverted: "bg-pf-cream text-pf-red",
};
---

<a
    href={href}
    target={external ? "_blank" : undefined}
    rel={external ? "noopener noreferrer" : undefined}
    class:list={[
        "rounded-md px-4 py-0 text-xl font-bold uppercase tracking-widest",
        "font-heading no-underline transition-opacity hover:opacity-90",
        variantStyles[variant],
        className,
    ]}
>
    {text}
</a>
