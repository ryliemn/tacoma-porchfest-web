---
import Button from "./Button.astro";

const ctaLinks = [
    { label: "Perform", href: "/perform" },
    { label: "Host", href: "/host" },
    { label: "Volunteer", href: "/volunteer" },
];
---

<div class="mt-12 md:mt-14 bg-pf-light-blue" aria-label="Get involved">
    <div class="flex items-center justify-center gap-3 px-4 pb-1 md:gap-4">
        {ctaLinks.map((link) => <Button href={link.href} text={link.label} />)}
    </div>
</div>
