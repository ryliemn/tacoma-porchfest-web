---
import Button from "./Button.astro";
import ClosedBadge from "./ClosedBadge.astro";
import HamburgerIcon from "./icons/HamburgerIcon.astro";

type NavChild = { label: string; href: string; external?: boolean };
type NavLink = {
    label: string;
    href?: string;
    external?: boolean;
    /** Render as a "Closed" popover trigger instead of a link (Perform). */
    closed?: boolean;
    children?: NavChild[];
};

const navLinks: NavLink[] = [
    { label: "Perform", closed: true },
    { label: "Host", href: "/host", external: true },
    { label: "Volunteer", href: "/volunteer", external: true },
    {
        label: "Schedule",
        children: [
            { label: "Saturday", href: "/schedule/saturday" },
            { label: "Sunday", href: "/schedule/sunday" },
        ],
    },
    { label: "FAQ", href: "/faq" },
    { label: "About", href: "/about" },
    { label: "Contact", href: "/contact" },
];

const donateHref = "https://www.paypal.com/donate/?hosted_button_id=QW4GDP26YJEKS";
---

<!--
    Desktop ordering: Logo, Nav links, Donate
    Mobile ordering: Hamburger, Logo, Donate
-->
<nav
    class="fixed top-0 left-0 right-0 z-50 bg-pf-sky-blue font-heading"
    aria-label="Main navigation"
>
    <div class="mx-auto flex h-12 items-center px-4 md:h-14">
        <div class="flex flex-1 items-center">
            <button
                id="menu-toggle"
                class="text-pf-red md:hidden"
                aria-expanded="false"
                aria-controls="mobile-menu"
                aria-label="Open menu"
            >
                <HamburgerIcon />
            </button>

            <a href="/" aria-label="Home" class="hidden md:block">
                <img src="/PF-Icon.svg" alt="Porchfest" class="h-10 w-auto" />
            </a>
        </div>

        <div class="hidden items-center gap-6 md:flex">
            {
                navLinks.map((link) =>
                    link.children ? (
                        <div class="group relative flex items-center">
                            <button
                                type="button"
                                class="flex items-center gap-1 text-xl text-pf-red transition-opacity hover:opacity-70"
                                aria-haspopup="true"
                            >
                                {link.label}
                                <svg
                                    class="h-3 w-3 transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
                                    viewBox="0 0 12 12"
                                    fill="none"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="M2 4.5 6 8.5l4-4"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    />
                                </svg>
                            </button>
                            <div class="invisible absolute left-1/2 top-full z-50 -translate-x-1/2 pt-3 opacity-0 transition-opacity duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                                <div class="flex flex-col gap-2 rounded-md border border-pf-red/10 bg-pf-sky-blue px-5 py-3 shadow-lg">
                                    {link.children.map((child) => (
                                        <a
                                            href={child.href}
                                            target={child.external ? "_blank" : undefined}
                                            rel={child.external ? "noopener noreferrer" : undefined}
                                            class="whitespace-nowrap text-xl text-pf-red no-underline transition-opacity hover:opacity-70"
                                        >
                                            {child.label}
                                        </a>
                                    ))}
                                </div>
                            </div>
                        </div>
                    ) : link.closed ? (
                        <button
                            type="button"
                            popovertarget="perform-closed"
                            class="flex cursor-pointer flex-col items-center gap-0.5 border-0 bg-transparent p-0 font-heading text-xl leading-none text-pf-red transition-opacity hover:opacity-70"
                        >
                            {link.label}
                            <ClosedBadge />
                        </button>
                    ) : (
                        <a
                            href={link.href}
                            target={link.external ? "_blank" : undefined}
                            rel={link.external ? "noopener noreferrer" : undefined}
                            class="text-xl text-pf-red no-underline transition-opacity hover:opacity-70"
                        >
                            {link.label}
                        </a>
                    )
                )
            }
        </div>

        <a href="/" aria-label="Home" class="md:hidden">
            <img src="/PF-Icon.svg" alt="Porchfest" class="h-10 w-auto" />
        </a>

        <div class="flex flex-1 items-center justify-end">
            <Button href={donateHref} text="Donate" external />
        </div>
    </div>

    <div
        id="mobile-menu"
        class="hidden border-t border-pf-red/10 bg-pf-sky-blue px-4 pb-4 pt-2 md:hidden"
    >
        {
            navLinks.map((link) =>
                link.children ? (
                    <div>
                        <p class="pt-3 pb-1 text-sm uppercase tracking-wide text-pf-red/60">
                            {link.label}
                        </p>
                        <div class="flex flex-col pl-4">
                            {link.children.map((child) => (
                                <a
                                    href={child.href}
                                    target={child.external ? "_blank" : undefined}
                                    rel={child.external ? "noopener noreferrer" : undefined}
                                    class="block py-2 text-xl text-pf-red no-underline transition-opacity hover:opacity-70"
                                >
                                    {child.label}
                                </a>
                            ))}
                        </div>
                    </div>
                ) : link.closed ? (
                    <button
                        type="button"
                        popovertarget="perform-closed"
                        class="block w-full cursor-pointer border-0 bg-transparent px-0 py-2 text-left font-heading text-xl text-pf-red transition-opacity hover:opacity-70"
                    >
                        {link.label}
                        <ClosedBadge class="ml-1 align-middle" />
                    </button>
                ) : (
                    <a
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noopener noreferrer" : undefined}
                        class="block py-2 text-xl text-pf-red no-underline transition-opacity hover:opacity-70"
                    >
                        {link.label}
                    </a>
                )
            )
        }
    </div>
</nav>

<script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const nav = document.querySelector("nav");

    function openMenu() {
        if (!toggle || !menu) return;
        toggle.setAttribute("aria-expanded", "true");
        toggle.setAttribute("aria-label", "Close menu");
        menu.classList.remove("hidden");
    }

    function closeMenu() {
        if (!toggle || !menu) return;
        toggle.setAttribute("aria-expanded", "false");
        toggle.setAttribute("aria-label", "Open menu");
        menu.classList.add("hidden");
    }

    toggle?.addEventListener("click", () => {
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        if (expanded) {
            closeMenu();
        } else {
            openMenu();
        }
    });

    document.addEventListener("click", (e) => {
        if (toggle?.getAttribute("aria-expanded") === "true" && !nav?.contains(e.target as Node)) {
            closeMenu();
        }
    });
</script>
