---
type Set = {
    time: string;
    name: string;
    durationMinutes: number | null;
    endTime?: string;
    tentative?: boolean;
};
type Porch = {
    address: string | null;
    venue: string | null;
    cluster: string | null;
    notes: string | null;
    sets: Set[];
    extra?: string[];
    block?: string | null;
};

interface Props {
    /** Heading, e.g. "Saturday" */
    day: string;
    /** Sub-heading, e.g. "July 18 · South of 6th Ave" */
    dateLabel: string;
    porches: Porch[];
    /**
     * Hour columns for the morning (before 3:00) and afternoon (3:00 on) tables.
     * Saturday omits a 3:00 column (parade hour) with pm ["4:00","5:00","6:00"];
     * Sunday has no parade with pm ["3:00","4:00","5:00"]. Defaults to Saturday.
     */
    columns?: { am: string[]; pm: string[] };
    /** Optional day map shown above the schedule. */
    mapSrc?: string;
    mapAlt?: string;
    /** The other festival day — powers cross-day artist search. */
    otherDay?: {
        label: string;
        href: string;
        artists: { name: string; block: string | null }[];
    };
}

const { day, dateLabel, porches, columns, mapSrc, mapAlt, otherDay } = Astro.props;

// Only show porches that actually have something scheduled.
const withSets = porches.filter((p) => p.sets.length > 0);

// Deep-link each porch to Google Maps (opens the Maps app if installed, else the
// browser). The city is appended so bare street addresses resolve to Tacoma.
const mapsHref = (p: Porch) =>
    `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
        `${p.address ?? p.venue ?? ""}, Tacoma, WA`,
    )}`;

// Unique artist name -> the block their porch is on (for search-to-highlight).
const artistPills: { name: string; block: string }[] = [];
const seenArtists = new Set<string>();
for (const p of withSets) {
    if (!p.block) continue;
    for (const s of p.sets) {
        const key = s.name.toLowerCase();
        if (seenArtists.has(key)) continue;
        seenArtists.add(key);
        artistPills.push({ name: s.name, block: p.block });
    }
}
const otherArtists = otherDay?.artists ?? [];

// The day splits into two tables at 3:00: a porch is in the morning table if it
// has a set starting before 3:00, in the afternoon table if it has one at/after
// 3:00. Each table renders its own hour-wide columns (passed per day). An act
// that doesn't start exactly on its column's hour is labeled with its real time;
// a continuous act spans multiple columns via colspan.
//
// Saturday's afternoon columns start at 4:00 (no 3:00 column — the parade hour),
// so 3:00/3:30 acts fold into the 4:00 column as time-labeled entries; a morning
// act that runs past 3:00 shows its full range so the spill reads. Sunday has no
// parade, so its afternoon columns start at 3:00.
const ALL_SLOTS = [
    "12:00", "12:30", "1:00", "1:30", "2:00", "2:30", "3:00", "3:30",
    "4:00", "4:30", "5:00", "5:30", "6:00", "6:30", "7:00",
];
const slotIdx = (t: string) => ALL_SLOTS.indexOf(t);
const SPLIT = slotIdx("3:00"); // afternoon table owns sets starting here on

type Entry = { name: string; note: string | null; tentative?: boolean };
type Cell = { entries: Entry[]; span: number };

// Label a set unless it exactly fills its column (starts on the column's hour and
// runs no longer than an hour). A set that runs past its column shows a start–end
// range so its duration reads even when it isn't drawn as a spanning bar.
function noteFor(s: Set, colLabel: string): string | null {
    const runsLong = !!s.endTime && slotIdx(s.endTime) > slotIdx(colLabel) + 2;
    if (runsLong) return s.endTime ? `${s.time}–${s.endTime}` : s.time;
    return s.time === colLabel ? null : s.time;
}

// Lay a porch's sets into hour-wide columns by start time. The first column of a
// table catches everything from `fromIdx` (so the afternoon's first column can
// pick up pre-column parade-hour acts). A lone long act spans later columns via
// colspan, but ONLY when nothing else occupies the columns it would cover — so a
// dense or back-to-back schedule never drops an act.
function rowCells(porch: Porch, cols: string[], fromIdx: number): Cell[] {
    const toEntry = (s: Set, colLabel: string): Entry => ({
        name: s.name,
        note: noteFor(s, colLabel),
        tentative: s.tentative,
    });
    const cells: Cell[] = [];
    for (let i = 0; i < cols.length;) {
        const colStart = slotIdx(cols[i]);
        const lower = i === 0 ? fromIdx : colStart; // first col catches earlier starts
        const colEnd = colStart + 2; // each hour column covers two half-hour slots
        const here = porch.sets.filter((s) => {
            const t = slotIdx(s.time);
            return t >= lower && t < colEnd;
        });
        const long = here.length === 1 && here[0].endTime && slotIdx(here[0].endTime!) > colEnd
            ? here[0]
            : null;
        if (long) {
            let cspan = 1;
            const end = slotIdx(long.endTime!);
            while (i + cspan < cols.length && slotIdx(cols[i + cspan]) < end) cspan++;
            const covered = i + cspan < cols.length ? slotIdx(cols[i + cspan]) : Infinity;
            const collision = porch.sets.some(
                (s) => s !== long && slotIdx(s.time) >= lower && slotIdx(s.time) < covered,
            );
            if (!collision) {
                cells.push({ entries: [toEntry(long, cols[i])], span: cspan });
                i += cspan;
                continue;
            }
        }
        cells.push({ entries: here.map((s) => toEntry(s, cols[i])), span: 1 });
        i++;
    }
    return cells;
}

const amCols = columns?.am ?? ["12:00", "1:00", "2:00"];
const pmCols = columns?.pm ?? ["4:00", "5:00", "6:00"];
const pages = [
    {
        cols: amCols,
        from: slotIdx(amCols[0]),
        porches: withSets.filter((p) => p.sets.some((s) => slotIdx(s.time) < SPLIT)),
    },
    {
        cols: pmCols,
        from: SPLIT,
        porches: withSets.filter((p) => p.sets.some((s) => slotIdx(s.time) >= SPLIT)),
    },
];
---

{/* Fixed header: title + map stay pinned below the navbar while tables scroll. */}
<div data-day-map class="sticky top-12 z-30 md:top-14">
    <section
        class="flex flex-col items-center justify-center bg-pf-red bg-cover bg-center py-2 md:py-3"
        style="background-image: url('/red-texture.webp');"
    >
        <h1 class="font-heading text-pf-brown text-2xl md:text-4xl uppercase text-center px-4">
            Schedule — {day}
        </h1>
        <p class="font-heading text-pf-brown/80 text-base md:text-lg uppercase mt-0.5">
            {dateLabel}
        </p>
    </section>
    {
        (mapSrc || Astro.slots.has("map")) && (
            <section class="bg-pf-yellow px-2 py-2 md:px-12 md:py-4">
                <slot name="map">
                    <img
                        src={mapSrc}
                        alt={mapAlt ?? `${day} festival map`}
                        class="block w-full md:mx-auto md:max-w-4xl md:rounded-md md:shadow-sm"
                    />
                </slot>
            </section>
        )
    }
</div>

<section
    id="schedule-section"
    class="min-h-screen bg-pf-cream px-1 pt-2 pb-12 md:px-6 md:pt-2 md:pb-16"
>
    {
        withSets.length === 0 ? (
            <p class="mx-auto max-w-3xl text-center font-heading text-pf-brown text-2xl md:text-3xl uppercase">
                Schedule coming soon
            </p>
        ) : (
            <div class="schedule mx-auto max-w-5xl">
                {/* Artist search — highlights the porch on this day, links to the other day. */}
                <div
                    class="mb-2"
                    data-search
                    data-artists={JSON.stringify(artistPills)}
                    data-other={JSON.stringify(otherArtists)}
                    data-other-label={otherDay?.label ?? ""}
                    data-other-href={otherDay?.href ?? ""}
                >
                    <input
                        type="search"
                        data-artist-search
                        placeholder="Search artists…"
                        autocomplete="off"
                        class="w-full rounded-full border-2 border-pf-red/40 bg-white px-5 py-1 font-heading text-pf-brown text-lg uppercase placeholder:text-pf-brown/40 focus:border-pf-red focus:outline-none"
                    />
                    <div data-artist-results hidden class="mt-2 flex flex-wrap gap-2" />
                </div>

                <div
                    id="schedule-filter"
                    hidden
                    class="mb-2 flex items-center justify-between gap-3 rounded-md bg-pf-yellow px-5 py-3 shadow-sm"
                >
                    <p class="font-heading text-pf-brown text-lg uppercase">
                        <span data-filter-count>0</span> <span data-filter-noun>porches</span> on
                        this block
                    </p>
                    <button
                        type="button"
                        data-filter-clear
                        class="cursor-pointer rounded-full bg-pf-red px-4 py-1.5 font-heading text-pf-cream text-sm uppercase transition-opacity hover:opacity-80"
                    >
                        Clear filter
                    </button>
                </div>

                {/* Both sessions stacked: early (12–3) on top, later (4–6) below. */}
                {pages.map(
                    (page, p) =>
                        page.porches.length > 0 && (
                            <div class="mb-4 last:mb-0" data-page={p}>
                                <table class="w-full table-fixed border-collapse text-pf-brown">
                                    <thead>
                                        <tr class="bg-pf-red text-pf-cream">
                                            <th class="w-[26%] p-1.5 text-left font-heading text-sm uppercase md:w-[22%] md:text-base">
                                                Porch
                                            </th>
                                            {page.cols.map((t) => (
                                                <th class="p-1.5 text-center font-heading text-sm tabular-nums md:text-lg">
                                                    {t}
                                                </th>
                                            ))}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {page.porches.map((porch) => (
                                            <tr
                                                data-block={porch.block ?? ""}
                                                data-addr={porch.address ?? porch.venue}
                                                class:list={[
                                                    "border-b border-pf-red/15 odd:bg-pf-cream/60",
                                                    porch.block &&
                                                        "cursor-pointer transition-colors hover:bg-pf-yellow/40",
                                                ]}
                                            >
                                                <th
                                                    scope="row"
                                                    class="p-1.5 text-left align-top font-heading text-sm leading-tight text-pf-brown uppercase md:text-lg"
                                                >
                                                    <div class="flex items-start gap-1">
                                                        <span class="min-w-0 flex-1">
                                                            {porch.venue ? (
                                                                <>
                                                                    {porch.venue}
                                                                    <span class="mt-0.5 block font-sans text-[10px] font-normal normal-case tracking-normal text-pf-brown/55 md:text-xs">
                                                                        {porch.address}
                                                                    </span>
                                                                </>
                                                            ) : (
                                                                porch.address ?? porch.venue
                                                            )}
                                                        </span>
                                                        <a
                                                            href={mapsHref(porch)}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                            title="Open in Google Maps"
                                                            aria-label={`Open ${porch.venue ?? porch.address ?? "porch"} in Google Maps`}
                                                            class="-m-1 shrink-0 p-1 text-pf-red/70 transition-colors hover:text-pf-red"
                                                        >
                                                            <svg
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                viewBox="0 0 24 24"
                                                                fill="currentColor"
                                                                aria-hidden="true"
                                                                class="h-4 w-4 md:h-5 md:w-5"
                                                            >
                                                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                                                            </svg>
                                                        </a>
                                                    </div>
                                                </th>
                                                {rowCells(porch, page.cols, page.from).map((cell) =>
                                                    cell.entries.length ? (
                                                        <td
                                                            colspan={cell.span}
                                                            class="space-y-1 border-l border-pf-red/15 p-1.5 align-top text-[11px] leading-tight md:text-sm"
                                                        >
                                                            {cell.entries.map((e) => (
                                                                <div>
                                                                    {e.name}
                                                                    {e.note && (
                                                                        <span class="whitespace-nowrap text-pf-brown/60">
                                                                            {" "}
                                                                            ({e.note})
                                                                        </span>
                                                                    )}
                                                                    {e.tentative && (
                                                                        <span class="text-pf-brown/50 italic">
                                                                            {" "}
                                                                            (tbd)
                                                                        </span>
                                                                    )}
                                                                </div>
                                                            ))}
                                                        </td>
                                                    ) : (
                                                        <td class="border-l border-pf-red/15 bg-pf-brown/10" />
                                                    ),
                                                )}
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        ),
                )}
            </div>
        )
    }
</section>

<script>
    const section = document.getElementById("schedule-section");
    const banner = document.getElementById("schedule-filter");
    if (section && banner) {
        // Both session tables are always visible; selecting a map block filters
        // their rows and hides any session with no porches on that block.
        const pageEls = Array.from(section.querySelectorAll<HTMLElement>("[data-page]"));
        const rows = Array.from(section.querySelectorAll<HTMLElement>("tr[data-block]"));
        const countEl = banner.querySelector("[data-filter-count]");
        const nounEl = banner.querySelector("[data-filter-noun]");
        const clearBtn = banner.querySelector("[data-filter-clear]");
        const mapEl = document.querySelector<HTMLElement>("[data-day-map]");

        // On a new filter, scroll the tables up just below the sticky map.
        function scrollToTable() {
            if (!section) return;
            const navH = window.matchMedia("(min-width: 768px)").matches ? 56 : 48;
            const mapH = mapEl?.getBoundingClientRect().height ?? 0;
            const top = section.getBoundingClientRect().top + window.scrollY - navH - mapH;
            window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
        }

        function apply(id: string | null) {
            const matchedAddrs = new Set<string>();
            rows.forEach((row) => {
                const match = !id || row.dataset.block === id;
                row.hidden = !match;
                if (match && id) matchedAddrs.add(row.dataset.addr ?? "");
            });
            // Hide a whole session table when the block has no porches in it.
            pageEls.forEach((pg) => {
                const visible = pg.querySelectorAll("tr[data-block]:not([hidden])").length;
                pg.hidden = id !== null && visible === 0;
            });
            banner.hidden = id === null;
            if (countEl) countEl.textContent = String(matchedAddrs.size);
            if (nounEl) nounEl.textContent = matchedAddrs.size === 1 ? "porch" : "porches";

            // Keep the URL in sync (shareable + survives reload); replaceState so
            // selections don't stack up in the browser's back history.
            const url = new URL(location.href);
            if (id) url.searchParams.set("block", id);
            else url.searchParams.delete("block");
            history.replaceState(null, "", url);

            if (id) scrollToTable();
        }

        document.addEventListener("pf:block", (e) =>
            apply((e as CustomEvent<string | null>).detail),
        );

        // Clicking a porch row selects its block (highlights the map + filters).
        // Clicks on the porch's Maps link are left alone so it opens directions.
        rows.forEach((row) => {
            row.addEventListener("click", (e) => {
                if ((e.target as Element).closest("a")) return;
                const id = row.dataset.block || null;
                if (id) document.dispatchEvent(new CustomEvent("pf:block", { detail: id }));
            });
        });

        clearBtn?.addEventListener("click", () =>
            document.dispatchEvent(new CustomEvent("pf:block", { detail: null })),
        );

        // --- artist search -------------------------------------------------
        type Artist = { name: string; block: string | null };
        const searchEl = document.querySelector<HTMLElement>("[data-search]");
        const input = searchEl?.querySelector<HTMLInputElement>("[data-artist-search]");
        const results = searchEl?.querySelector<HTMLElement>("[data-artist-results]");
        if (searchEl && input && results) {
            const here: Artist[] = JSON.parse(searchEl.dataset.artists || "[]");
            const there: Artist[] = JSON.parse(searchEl.dataset.other || "[]");
            const otherLabel = searchEl.dataset.otherLabel || "";
            const otherHref = searchEl.dataset.otherHref || "";

            const dedupe = (list: Artist[]) => {
                const seen = new Set<string>();
                return list.filter((a) => {
                    const k = a.name.toLowerCase();
                    if (seen.has(k)) return false;
                    seen.add(k);
                    return true;
                });
            };

            function render(q: string) {
                results!.replaceChildren();
                if (!q) {
                    results!.hidden = true;
                    return;
                }
                const ql = q.toLowerCase();
                const hits = dedupe(
                    here.filter((a) => a.block && a.name.toLowerCase().includes(ql)),
                ).slice(0, 6);
                const others = dedupe(there.filter((a) => a.name.toLowerCase().includes(ql))).slice(
                    0,
                    4,
                );

                for (const a of hits) {
                    const b = document.createElement("button");
                    b.type = "button";
                    b.className =
                        "cursor-pointer rounded-full bg-pf-red px-3 py-1.5 font-heading text-sm text-pf-cream uppercase transition-opacity hover:opacity-80";
                    b.textContent = a.name;
                    b.addEventListener("click", () => {
                        input!.value = "";
                        render("");
                        document.dispatchEvent(new CustomEvent("pf:block", { detail: a.block }));
                    });
                    results!.appendChild(b);
                }

                if (others.length) {
                    const label = document.createElement("span");
                    label.className = "w-full pt-1 font-heading text-pf-brown/60 text-xs uppercase";
                    label.textContent = `Playing ${otherLabel}`;
                    results!.appendChild(label);
                    for (const a of others) {
                        const link = document.createElement("a");
                        link.className =
                            "rounded-full border-2 border-pf-red/50 px-3 py-1.5 font-heading text-sm text-pf-brown uppercase no-underline transition-colors hover:bg-pf-red/10";
                        link.href = a.block
                            ? `${otherHref}?block=${encodeURIComponent(a.block)}`
                            : otherHref;
                        link.textContent = `${a.name} ↗`;
                        results!.appendChild(link);
                    }
                }

                if (!hits.length && !others.length) {
                    const none = document.createElement("span");
                    none.className = "font-heading text-pf-brown/50 text-sm uppercase";
                    none.textContent = "No artists found";
                    results!.appendChild(none);
                }
                results!.hidden = false;
            }

            input.addEventListener("input", () => render(input.value.trim()));
        }

        // Cross-day deep link: /schedule/<day>?block=N selects it on load.
        const deep = new URLSearchParams(location.search).get("block");
        if (deep) {
            window.addEventListener("load", () =>
                document.dispatchEvent(new CustomEvent("pf:block", { detail: deep })),
            );
        }
    }
</script>
