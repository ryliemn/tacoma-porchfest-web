---
interface Props {
    question: string;
}

const { question } = Astro.props;
---

<details open class="group border-b border-pf-brown/20 pb-4">
    <summary class="font-heading text-pf-brown text-base md:text-lg cursor-pointer list-none flex items-start justify-between gap-4">
        <span>{question}</span>
        <span class="text-pf-brown/60 group-open:rotate-45 transition-transform text-xl leading-none mt-0.5">+</span>
    </summary>
    <div class="font-body text-pf-brown text-sm md:text-base leading-relaxed mt-3">
        <slot />
    </div>
</details>
