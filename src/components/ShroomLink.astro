---
interface Props {
    href: string;
    image: string;
    label: string;
    /** Tailwind text-color class for the label (e.g. "text-pf-red"). */
    labelClass: string;
}

const { href, image, label, labelClass } = Astro.props;
---

<a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="flex basis-[44%] flex-col items-center transition-transform hover:scale-105 active:scale-95 sm:grow sm:basis-0"
>
    <div class="flex h-28 w-full items-end justify-center sm:h-44">
        <img src={image} alt="" class="max-h-full max-w-full" />
    </div>
    <span
        class:list={[
            "mt-1 text-center font-heading text-2xl sm:text-4xl uppercase font-medium",
            labelClass,
        ]}
    >
        {label}
    </span>
</a>
