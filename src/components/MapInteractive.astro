---
// Interactive festival map: the labeled SVG (public/Map-{North,South}.svg) is
// inlined so each city block <g id="N" class="block"> can be styled and
// tapped directly. Blocks with porches are highlighted + tappable; tapping one
// dispatches "pf:block" so the schedule table can filter to it.
// Inline the SVG source at build time (?raw) so we can style/tap its blocks.
import northSvg from "../../public/Map-North.svg?raw";
import southSvg from "../../public/Map-South.svg?raw";

interface Props {
    /** Which map to render. */
    map: "north" | "south";
    /** Block ids (e.g. "7") that have porches — these become tappable. */
    highlightBlocks?: string[];
    alt?: string;
}
const { map, highlightBlocks = [], alt = "Festival map" } = Astro.props;

// Drop the XML prolog so the SVG embeds cleanly inside the HTML document.
const svg = (map === "north" ? northSvg : southSvg).replace(/<\?xml[^>]*\?>/, "").trim();
---

<div
    class="map-interactive relative mx-auto block w-full md:max-w-4xl"
    role="img"
    aria-label={alt}
    data-has-porches={JSON.stringify(highlightBlocks)}
>
    <Fragment set:html={svg} />
</div>

<style is:global>
    .map-interactive svg {
        display: block;
        width: 100%;
        height: auto;
    }
    .map-interactive .block {
        transition: filter 0.12s ease;
    }
    /* Blocks without porches: dimmed and inert. Uses a muted fill + opacity
       rather than a CSS filter, because mobile Safari drops CSS filters on
       inline SVG groups (which made the dimming vanish on phones). */
    .map-interactive .block:not(.has-porches) {
        opacity: 0.55;
        pointer-events: none;
    }
    .map-interactive .block:not(.has-porches) .cls-1,
    .map-interactive .block:not(.has-porches) .cls-7,
    .map-interactive .block:not(.has-porches) .cls-10,
    .map-interactive .block:not(.has-porches) .cls-11,
    .map-interactive .block:not(.has-porches) .cls-east {
        fill: #9b968a;
    }
    /* Blocks with porches: tappable. */
    .map-interactive .block.has-porches {
        cursor: pointer;
    }
    .map-interactive .block.has-porches:hover {
        filter: brightness(1.08) saturate(1.3);
    }
    /* Selected block: bold red fill + navy outline so it clearly stands out. */
    .map-interactive .block.is-active {
        filter: drop-shadow(0 0 2px #20425d) drop-shadow(0 0 1px #20425d);
    }
    .map-interactive .block.is-active .cls-1, /* south inner */
    .map-interactive .block.is-active .cls-10, /* north inner */
    .map-interactive .block.is-active .cls-east { /* north solid east block */
        fill: #f93e10;
    }
    .map-interactive .block.is-active .cls-7, /* south frame */
    .map-interactive .block.is-active .cls-11 { /* north frame */
        fill: #b8431b;
    }
</style>

<script>
    // DEBUG: overlay each block's id number on the map. Flip to false to hide.
    const DEBUG_BLOCK_NUMBERS = false;

    document.querySelectorAll<HTMLElement>(".map-interactive").forEach((root) => {
        const svg = root.querySelector("svg");
        if (!svg) return;
        const withPorches = new Set<string>(JSON.parse(root.dataset.hasPorches || "[]"));
        const blocks = Array.from(root.querySelectorAll<SVGGElement>("g.block"));
        blocks.forEach((g) => {
            if (withPorches.has(g.id)) g.classList.add("has-porches");
        });

        // Paint the block id at each block's centre (SVG has no transforms, so a
        // block's getBBox is already in root user space). Appended to the root so
        // the labels sit on top at full opacity, untouched by block dimming.
        if (DEBUG_BLOCK_NUMBERS) {
            const NS = "http://www.w3.org/2000/svg";
            for (const g of blocks) {
                const b = g.getBBox();
                if (!b.width || !b.height) continue;
                const fs = Math.max(5, Math.min(b.width * 0.35, b.height * 0.5));
                const t = document.createElementNS(NS, "text");
                t.textContent = g.id;
                t.setAttribute("x", String(b.x + b.width / 2));
                t.setAttribute("y", String(b.y + b.height / 2));
                t.setAttribute("text-anchor", "middle");
                t.setAttribute("dominant-baseline", "central");
                t.setAttribute("font-size", String(fs));
                t.setAttribute("font-weight", "700");
                t.setAttribute("fill", "#0b1f3a");
                t.setAttribute("stroke", "#fff");
                t.setAttribute("stroke-width", String(fs * 0.14));
                t.setAttribute("paint-order", "stroke");
                t.setAttribute("pointer-events", "none");
                svg.appendChild(t);
            }
        }

        let selected: string | null = null;

        // Reflect the current selection — fired by map clicks OR table clicks.
        document.addEventListener("pf:block", (e) => {
            selected = (e as CustomEvent<string | null>).detail;
            blocks.forEach((g) =>
                g.classList.toggle("is-active", selected !== null && g.id === selected),
            );
        });

        svg.addEventListener("click", (e) => {
            const g = (e.target as Element).closest<SVGGElement>("g.block.has-porches");
            if (!g) return;
            // Toggle: clicking the selected block again clears the selection.
            const id = g.id === selected ? null : g.id;
            document.dispatchEvent(new CustomEvent("pf:block", { detail: id }));
        });
    });
</script>
