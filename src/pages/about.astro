---
import Button from "../components/Button.astro";
import Base from "../layouts/Base.astro";

const donateHref = "https://account.venmo.com/u/tacomaporchfest";
---

<Base title="About - Tacoma Porchfest">
    <section
        class="flex items-center justify-center bg-pf-red bg-cover bg-center py-8"
        style="background-image: url('/red-texture.webp');"
    >
        <div class="flex flex-col items-center text-center px-4 max-w-3xl">
            <h1 class="font-heading text-pf-brown text-4xl md:text-6xl uppercase">About</h1>
            <p
                class="mt-4 mb-8 font-body text-pf-cream text-base md:text-lg font-medium leading-relaxed"
            >
                Tacoma Porchfest's mission is to provide barrier-free arts and cultural experiences
                AND to build community connections through music, joyful celebration, and
                collaborative placemaking.
            </p>
            <Button href={donateHref} text="Donate" variant="inverted" external />
        </div>
    </section>
    <section class="bg-pf-yellow px-6 py-12 md:px-12 md:py-16">
        <div class="mx-auto max-w-4xl">
            <h1 class="font-heading text-pf-brown text-3xl md:text-5xl uppercase mb-8 md:mb-12">
                Five Years of Tacoma Porchfest
            </h1>
            <div class="flex flex-col md:flex-row gap-8 md:gap-12">
                <div class="md:w-2/3">
                    <h2
                        class="font-heading text-pf-brown text-lg md:text-2xl font-medium mb-6 leading-snug"
                    >
                        Porchfest is a free community festival transforming Central and North Tacoma
                        into an all-ages, walkable music celebration.
                    </h2>
                    <p class="font-body text-pf-brown text-sm md:text-base leading-relaxed">
                        How does it work? Residents within the festival boundaries sign up as porch
                        hosts, and performers are matched to these cozy "stages," creating a
                        festival that is large in scale (over 300 bands in 2025), yet intimate and
                        neighborly.
                    </p>
                </div>
                <div class="md:w-1/3">
                    <img
                        src="/image-6.avif"
                        alt=""
                        class="rounded-sm object-cover aspect-3/4 w-full"
                    />
                </div>
            </div>
        </div>
    </section>
    <section class="bg-pf-yellow px-6 py-4 md:px-12">
        <div class="mx-auto max-w-4xl">
            <div class="flex flex-col-reverse md:flex-row gap-8 md:gap-12">
                <div class="md:w-1/3 grid grid-cols-1 gap-4">
                    <img
                        src="/image-4.avif"
                        alt=""
                        class="rounded-sm object-cover aspect-4/3 w-full"
                    />
                    <img
                        src="/image-5.avif"
                        alt=""
                        class="rounded-sm object-cover aspect-4/3 w-full"
                    />
                </div>
                <div class="md:w-2/3">
                    <h2
                        class="font-heading text-pf-brown text-lg md:text-2xl font-medium mb-4 leading-snug"
                    >
                        Music and outdoor festivals are great vehicles for community building
                    </h2>
                    <p class="font-body text-pf-brown text-sm md:text-base leading-relaxed mb-8">
                        What makes Porchfest truly special is its reimagining of private spaces.
                        Yards and porches which are typically "off limits," transform into joyful,
                        welcoming gathering spots where diverse groups of people gather to enjoy
                        music, dancing, conversation and meaningful connections.
                    </p>
                    <h2
                        class="font-heading text-pf-brown text-lg md:text-2xl font-medium mb-4 leading-snug"
                    >
                        We aim to build lasting community connections in Tacoma.
                    </h2>
                </div>
            </div>
        </div>
    </section>
    <section class="bg-pf-yellow px-6 py-12 md:px-12 md:py-16">
        <div class="mx-auto max-w-4xl">
            <div class="flex flex-col md:flex-row gap-8 md:gap-12">
                <div class="md:w-1/2">
                    <div class="font-body text-pf-brown text-sm md:text-base leading-relaxed mb-8">
                        <p>
                            Tacoma Porchfest is organized by community members in partnership with
                            Central Neighborhood Council, North End Neighborhood Council, and the
                            Sixth Ave Business District.
                        </p>
                        <p class="mt-4">
                            The festival is made possible with funding from Tacoma Venues &amp;
                            Events and individual donations from festival attendees.
                        </p>
                        <p class="mt-4">Tacoma Porchfest is a designated City Event.</p>
                    </div>
                    <h2 class="font-heading text-pf-brown text-3xl md:text-5xl mb-6 leading-tight">
                        This machine builds community.
                    </h2>
                    <div class="flex justify-center md:justify-start">
                        <Button href={donateHref} text="Donate" external />
                    </div>
                </div>
                <div
                    class="md:w-1/2 flex flex-wrap justify-center gap-6 items-center content-center"
                >
                    <img
                        src="/city_of_tacoma.avif"
                        alt="City of Tacoma"
                        class="max-h-36 object-contain mx-auto"
                    />
                    <img
                        src="/tacoma_venues_and_events.avif"
                        alt="Tacoma Venues & Events"
                        class="max-h-28 object-contain mx-auto"
                    />
                    <img
                        src="/central_neighborhood_council.avif"
                        alt="Central Neighborhood Council"
                        class="max-h-28 object-contain mx-auto"
                    />
                    <img
                        src="/north_end_neighborhood_council.avif"
                        alt="North End Neighborhood Council"
                        class="max-h-28 object-contain mx-auto"
                    />
                    <img
                        src="/sixth_ave.avif"
                        alt="6th Ave Business District"
                        class="max-h-28 object-contain mx-auto bg-white rounded-sm p-2"
                    />
                </div>
            </div>
        </div>
    </section>
</Base>
