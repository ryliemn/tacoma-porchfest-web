---
import Base from "../layouts/Base.astro";
---

<Base
    title="Workshops - Tacoma Porchfest"
    description="Free, all-ages music workshops leading up to Tacoma Porchfest 2026."
>
    <section
        class="flex flex-col items-center justify-center gap-3 bg-pf-red bg-cover bg-center px-4 py-10 text-center"
        style="background-image: url('/red-texture.webp');"
    >
        <h1 class="font-heading text-pf-brown text-4xl md:text-6xl uppercase">Workshops</h1>
        <p class="max-w-2xl font-heading text-pf-cream text-xl md:text-2xl uppercase font-medium">
            Hands-on music workshops leading up to Porchfest. Come make something, then bring it to
            the stage.
        </p>
    </section>

    <section class="bg-pf-yellow px-4 py-12 md:px-12 md:py-16">
        <div class="mx-auto flex max-w-3xl flex-col items-center text-center gap-6">
            <div class="flex w-full items-center justify-center gap-3 md:gap-6">
                <img src="/lions-mane.svg" alt="" class="w-16 shrink-0 sm:w-28" />
                <h2 class="font-heading text-pf-brown text-4xl md:text-6xl uppercase font-medium">
                    Tape Loop Workshop
                </h2>
                <img src="/lions-mane.svg" alt="" class="w-16 shrink-0 sm:w-28 scale-x-[-1]" />
            </div>

            <div class="flex flex-col items-center gap-1">
                <p class="font-heading text-pf-brown text-2xl md:text-3xl uppercase font-medium">
                    Tacoma Public Library &middot; Main Branch
                </p>
                <a
                    href="https://maps.google.com/?q=1102+Tacoma+Ave+S+Tacoma+WA+98402"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-body text-pf-brown text-base md:text-lg underline transition-opacity hover:opacity-70"
                >
                    Olympic Room &middot; 1102 Tacoma Ave S, Tacoma, WA 98402
                </a>
            </div>

            <div class="flex flex-col items-center gap-4 max-w-2xl">
                <p class="font-body text-pf-brown text-base md:text-lg">
                    Come and learn the esoteric art of making a tape loop. All materials will be
                    supplied and we will be on hand to make sure you walk out with your very own
                    tape loop. If you&rsquo;d like to record something onto your tape, there will be
                    a variety of synthesizers to record your own loop with.
                </p>
                <p class="font-body text-pf-brown text-base md:text-lg">
                    As a grand finale of the workshops, you&rsquo;ll be invited to a Porchfest
                    fundraiser at Lumora on the evening of the 27th to play and perform your tape.
                    We will be setting up for an ambient / Musique concr&egrave;te performance where
                    we will welcome everyone who made a tape to share their found sound with us!
                </p>
            </div>

            <div class="flex flex-col items-center gap-3 w-full">
                <div class="flex w-full flex-col gap-4 md:flex-row md:gap-6">
                    <a
                        href="https://tacoma.bibliocommons.com/events/69f3e75c129f1274383be7f8"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex flex-1 flex-col items-center gap-1 rounded-2xl bg-pf-brown px-6 py-5 text-pf-cream no-underline transition-opacity hover:opacity-80"
                    >
                        <span class="font-heading text-lg md:text-xl uppercase tracking-widest">
                            Part One
                        </span>
                        <span class="font-heading text-2xl md:text-3xl uppercase">
                            Saturday, June 20
                        </span>
                        <span class="font-heading text-lg md:text-xl uppercase">
                            3:30 &ndash; 5:00 PM
                        </span>
                        <span class="font-body text-sm md:text-base underline pt-1">Details</span>
                    </a>
                    <a
                        href="https://tacoma.bibliocommons.com/events/69f3e94b8ddc1caf5f2058a7"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex flex-1 flex-col items-center gap-1 rounded-2xl bg-pf-brown px-6 py-5 text-pf-cream no-underline transition-opacity hover:opacity-80"
                    >
                        <span class="font-heading text-lg md:text-xl uppercase tracking-widest">
                            Part Two
                        </span>
                        <span class="font-heading text-2xl md:text-3xl uppercase">
                            Saturday, June 27
                        </span>
                        <span class="font-heading text-lg md:text-xl uppercase">
                            12:00 &ndash; 1:30 PM
                        </span>
                        <span class="font-body text-sm md:text-base underline pt-1">Details</span>
                    </a>
                </div>
            </div>

            <div class="flex flex-col items-center gap-3 pt-2">
                <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
                    <span
                        class="bg-pf-red text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Free
                    </span>
                    <span
                        class="bg-pf-blue text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        All Ages &middot; Grades 9&ndash;12 &amp; Up
                    </span>
                    <span
                        class="bg-pf-brown text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Materials Provided
                    </span>
                </div>
                <p class="font-body text-pf-brown text-base md:text-lg">
                    Presented by Tacoma Porchfest, hosted by Tacoma Public Library, and funded by
                    City of Tacoma / Tacoma Creates.
                </p>
            </div>
        </div>
    </section>
</Base>
