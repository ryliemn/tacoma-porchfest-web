---
import InstagramFeed from "../components/InstagramFeed.astro";
import MailIcon from "../components/icons/MailIcon.astro";
import Base from "../layouts/Base.astro";
---

<Base title="Contact - Tacoma Porchfest">
    <section class="bg-pf-cream px-6 pt-8 pb-16">
        <div class="mx-auto max-w-3xl text-center">
            <h1 class="font-heading text-pf-red text-4xl md:text-6xl uppercase mb-8">Contact</h1>
            <a
                href="mailto:info@tacomaporchfest.org"
                class="inline-flex items-center gap-3 font-body text-pf-brown text-xl no-underline hover:opacity-80 transition-opacity"
            >
                <MailIcon />
                info@tacomaporchfest.org
            </a>
        </div>
    </section>
    <InstagramFeed class="px-4 py-8" />
</Base>
