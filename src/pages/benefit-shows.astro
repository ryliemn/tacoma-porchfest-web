---
import Base from "../layouts/Base.astro";
---

<Base
    title="Benefit Shows - Tacoma Porchfest"
    description="Free, all-ages benefit concerts leading up to Tacoma Porchfest 2026."
>
    <section
        class="flex flex-col items-center justify-center gap-3 bg-pf-red bg-cover bg-center px-4 py-10 text-center"
        style="background-image: url('/red-texture.webp');"
    >
        <h1 class="font-heading text-pf-brown text-4xl md:text-6xl uppercase">Benefit Shows</h1>
        <p class="max-w-2xl font-heading text-pf-cream text-xl md:text-2xl uppercase font-medium">
            Two free nights of live music leading up to Porchfest. Come out, chip in, and help us
            build community.
        </p>
    </section>

    <section class="bg-pf-blue px-4 py-12 md:px-12 md:py-16">
        <div class="mx-auto flex max-w-3xl flex-col items-center text-center gap-6">
            <div class="flex w-full items-center justify-center gap-3 md:gap-6">
                <img src="/shroom-left.svg" alt="" class="w-12 shrink-0 sm:w-20" />
                <h2
                    class="font-heading text-pf-off-white text-4xl md:text-6xl uppercase font-medium"
                >
                    Saturday, June 6
                </h2>
                <img src="/shroom-right.svg" alt="" class="w-12 shrink-0 sm:w-20" />
            </div>

            <div class="flex flex-col items-center gap-1">
                <p class="font-heading text-pf-cream text-2xl md:text-3xl uppercase font-medium">
                    The Mothership
                </p>
                <p class="font-body text-pf-cream text-sm md:text-base italic">
                    home of Tacoma Night Market
                </p>
                <a
                    href="https://maps.google.com/?q=5407+South+Washington+Street+Tacoma+WA+98409"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-body text-pf-cream text-base md:text-lg underline transition-opacity hover:opacity-70"
                >
                    5407 South Washington Street, Tacoma, WA 98409
                </a>
            </div>

            <p class="font-heading text-pf-cream text-xl md:text-2xl uppercase font-medium">
                Doors at 6pm &middot; Music at 7pm
            </p>

            <div class="flex flex-col items-center gap-3">
                <p
                    class="font-heading text-pf-off-white text-lg md:text-xl uppercase font-medium tracking-widest"
                >
                    Lineup
                </p>
                <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
                    <span
                        class="bg-pf-cream text-pf-navy rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        My Chemical Fauxmance
                    </span>
                    <span
                        class="bg-pf-cream text-pf-navy rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Hard Softee
                    </span>
                    <span
                        class="bg-pf-cream text-pf-navy rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Kuwaisiana
                    </span>
                    <span
                        class="font-body text-pf-cream text-lg md:text-xl font-medium self-center"
                    >
                        + more!
                    </span>
                </div>
            </div>

            <div class="flex flex-col items-center gap-3 pt-2">
                <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
                    <span
                        class="bg-pf-red text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Free &middot; No Cover
                    </span>
                    <span
                        class="bg-pf-yellow text-pf-brown rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        All Ages
                    </span>
                </div>
                <p class="font-body text-pf-cream text-base md:text-lg">
                    Beer, wine, and other beverages available for purchase.
                </p>
            </div>
        </div>
    </section>

    <section class="bg-pf-yellow px-4 py-12 md:px-12 md:py-16">
        <div class="mx-auto flex max-w-3xl flex-col items-center text-center gap-6">
            <div class="flex w-full items-center justify-center gap-3 md:gap-6">
                <img src="/lions-mane.svg" alt="" class="w-16 shrink-0 sm:w-28" />
                <h2 class="font-heading text-pf-brown text-4xl md:text-6xl uppercase font-medium">
                    Saturday, June 27
                </h2>
                <img src="/lions-mane.svg" alt="" class="w-16 shrink-0 sm:w-28 scale-x-[-1]" />
            </div>

            <div class="flex flex-col items-center gap-1">
                <p class="font-heading text-pf-brown text-2xl md:text-3xl uppercase font-medium">
                    The Lumora
                </p>
                <a
                    href="https://maps.google.com/?q=724+Pacific+Ave+Tacoma+WA+98402"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-body text-pf-brown text-base md:text-lg underline transition-opacity hover:opacity-70"
                >
                    724 Pacific Ave, Tacoma, WA 98402
                </a>
            </div>

            <p class="font-heading text-pf-brown text-xl md:text-2xl uppercase font-medium">
                Doors at 6pm &middot; Music at 7pm
            </p>

            <div class="flex flex-col items-center gap-3">
                <p
                    class="font-heading text-pf-brown text-lg md:text-xl uppercase font-medium tracking-widest"
                >
                    Lineup
                </p>
                <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
                    <span
                        class="bg-pf-brown text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        F00F
                    </span>
                    <span
                        class="bg-pf-brown text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Haystack Slim &amp; the Broken Arrow
                    </span>
                    <span
                        class="bg-pf-brown text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Tacoma Noise Rodeo
                    </span>
                    <span
                        class="font-body text-pf-brown text-lg md:text-xl font-medium self-center"
                    >
                        + more!
                    </span>
                </div>
            </div>

            <div class="flex flex-col items-center gap-3 pt-2">
                <div class="flex flex-wrap items-center justify-center gap-2 md:gap-3">
                    <span
                        class="bg-pf-red text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        Free &middot; No Cover
                    </span>
                    <span
                        class="bg-pf-blue text-pf-cream rounded-full px-4 py-1 font-heading text-lg md:text-xl uppercase"
                    >
                        All Ages
                    </span>
                </div>
                <p class="font-body text-pf-brown text-base md:text-lg">
                    Beer, wine, and other beverages available for purchase.
                </p>
            </div>
        </div>
    </section>
</Base>
