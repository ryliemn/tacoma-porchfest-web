---
import DonateButton from "../components/DonateButton.astro";
import Base from "../layouts/Base.astro";
---

<Base
    description="Tacoma Porchfest is a free, walkable music festival that takes place on porches in Tacoma, Washington."
>
    <section
        class="flex items-center justify-center bg-pf-red bg-cover bg-center py-8"
        style="background-image: url('/red-texture.webp');"
    >
        <img
            src="/Hero-Full-Lockup.svg"
            alt="Tacoma Porchfest 2026 — July 18 & 19 — Free Live Music"
            class="w-[85vw] max-w-2xl px-4 py-8 md:py-16"
        />
    </section>
    <section class="bg-pf-yellow px-4">
        <div class="relative -top-8 mx-auto w-[95%] max-w-230 md:-top-12">
            <img
                src="/Rough-Container.svg"
                alt=""
                class="w-full absolute"
                width="1766"
                height="910"
            />
            <div class="flex flex-col items-center pt-2 md:pt-8 text-center z-10 relative">
                <h2 class="font-heading text-pf-red text-2xl md:text-5xl uppercase font-medium">
                    <span>Saturday, July 18<sup>th</sup></span>
                    <br />
                    <span>Sunday July 19<sup>th</sup></span>
                </h2>
                <p
                    class="md:mt-2 mb-8 px-2 max-w-3xl font-heading text-pf-blue text-lg md:text-2xl font-light"
                >
                    Porchfest is a free, walkable music festival that takes place on porches. Come
                    meet your neighbors and find your new favorite band!
                </p>
                <div class="mx-auto flex gap-4 w-[90%] justify-around flex-wrap -top-20">
                    <img
                        src="/image-1.avif"
                        alt=""
                        class="rounded-sm object-cover aspect-4/3 min-w-20 max-w-65"
                    />
                    <img
                        src="/image-2.avif"
                        alt=""
                        class="rounded-sm object-cover aspect-4/3 min-w-20 max-w-65"
                    />
                    <img
                        src="/image-3.avif"
                        alt=""
                        class="rounded-sm object-cover aspect-4/3 min-w-20 max-w-65"
                    />
                </div>
                <div class="text-pf-brown md:my-16 my-8 font-body">
                    <h2 class="font-heading text-lg mb-2">This machine builds community.</h2>
                    <div class="text-sm font-light">
                        <p>
                            Tacoma Porchfest is organized by community members in partnership with
                            Central Neighborhood Council, North End Neighborhood Council, and the
                            Sixth Ave Business District.
                        </p>
                        <p>
                            It is made possible with funding from Tacoma Venues & Events and
                            individual donations from festival attendees.
                        </p>
                        <p>Tacoma Porchfest is a City of Tacoma Sponsored Event.</p>
                    </div>
                </div>
                <DonateButton />
            </div>
        </div>
    </section>
</Base>
