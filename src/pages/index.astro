---
import Base from "../layouts/Base.astro";
import FacebookIcon from "../components/icons/FacebookIcon.astro";
import InstagramIcon from "../components/icons/InstagramIcon.astro";
import MailIcon from "../components/icons/MailIcon.astro";
---

<Base
    description="Tacoma Porchfest is a free, walkable music festival that takes place on porches in Tacoma, Washington."
>
    <div
        class="flex h-full items-center justify-center
            pl-[max(1rem,env(safe-area-inset-left))]
            pr-[max(1rem,env(safe-area-inset-right))]
            pt-[max(2rem,env(safe-area-inset-top))]
            pb-[max(2rem,env(safe-area-inset-bottom))]"
    >
        <main class="flex flex-col items-center text-center max-w-160">
            <img
                src="/crow.webp"
                alt="Illustrated crow singing into a microphone"
                class="max-w-80 w-[60vw]"
                width="316"
                height="279"
            />
            <h1 class="font-display mt-6 text-3xl md:text-5xl text-shadow-sm">
                Tacoma Porchfest
            </h1>
            <p class="leading-relaxed mt-4 max-w-lg text-lg text-shadow-sm">
                Porchfest is a free, walkable music festival that takes place on porches.
            </p>
            <p class="leading-relaxed mt-4 max-w-lg text-lg text-shadow-sm">
                Information about Porchfest 2026 is coming soon!
            </p>
            <nav aria-label="Social media" class="flex gap-6 mt-8">
                <a
                    href="https://www.facebook.com/TacomaPorchFest/"
                    target="_blank"
                    aria-label="Facebook"
                    class="social-link"
                >
                    <FacebookIcon />
                </a>
                <a
                    href="https://www.instagram.com/tacomaporchfest"
                    target="_blank"
                    aria-label="Instagram"
                    class="social-link"
                >
                    <InstagramIcon />
                </a>
                <a href="#" aria-label="Email" class="social-link">
                    <MailIcon />
                </a>
            </nav>
        </main>
    </div>
</Base>
