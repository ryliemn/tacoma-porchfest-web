---
import Button from "../components/Button.astro";
import Carousel from "../components/Carousel.astro";
import ClosedBadge from "../components/ClosedBadge.astro";
import FramedPhoto from "../components/FramedPhoto.astro";
import ShroomLink from "../components/ShroomLink.astro";
import Base from "../layouts/Base.astro";
---

<Base
    description="Tacoma Porchfest is a free, walkable music festival that takes place on porches in Tacoma, Washington."
>
    <section class="flex flex-col items-center bg-pf-cream">
        <div class="hero-crop">
            <img
                src="/hero_v2.webp"
                alt="Tacoma Porchfest 2026 — July 18 & 19 — Free Live Music"
                class="block h-full w-full object-cover object-center"
            />
        </div>
        <div class="flex items-center justify-center gap-4 relative top-4">
            <div class="relative">
                <ClosedBadge class="absolute -top-5 left-1/2 z-10 -translate-x-1/2" />
                <Button text="Perform" variant="blue" popovertarget="perform-closed" />
            </div>
            <Button
                href="https://forms.gle/5DRSttNLzSgi3pxh8"
                text="Host"
                variant="blue"
                external
            />
            <Button
                href="https://forms.gle/HB6YgTvMBpBNP4C27"
                text="Volunteer"
                variant="blue"
                external
            />
        </div>
    </section>
    <section class="red-arc bg-pf-red px-4 py-8">
        <div class="mx-auto flex max-w-4xl flex-col items-center text-center gap-4">
            <div class="flex items-center justify-center gap-4">
                <img src="/music-bar-left.svg" class="sm:w-30 w-20" />
                <p class="font-heading text-pf-cream text-2xl uppercase font-medium">
                    Free Live Music
                </p>
                <img src="/music-bar-right.svg" class="sm:w-30 w-20" />
            </div>
            <div class="flex w-full items-center justify-between gap-2">
                <img
                    src="/shroom-left.svg"
                    class="sm:w-20 w-12 shrink-0"
                    width="142"
                    height="132"
                />
                <h2
                    class="font-heading text-pf-off-white sm:text-4xl text-3xl uppercase font-medium"
                >
                    <span>Saturday, July 18</span>
                    <br />
                    <span>Sunday, July 19</span>
                </h2>
                <img
                    src="/shroom-right.svg"
                    class="sm:w-20 w-12 shrink-0"
                    width="164"
                    height="126"
                />
            </div>
            <p class="max-w-2xl font-heading text-pf-cream text-2xl uppercase font-medium">
                Porchfest is a free, walkable music festival that takes place on porches. Come meet
                your neighbors and find your new favorite band!
            </p>
        </div>
    </section>
    <section>
        <img
            src="/photos/home-main.webp"
            alt="A crowd gathered for a backyard performance at Tacoma Porchfest"
            class="photo-fade mx-auto block h-[clamp(200px,42vw,460px)] w-full max-w-4xl object-cover object-bottom"
        />
    </section>
    <section class="bg-pf-blue px-4 py-6">
        <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 md:flex-row">
            <img
                src="/map-split-ampm.webp"
                alt="Tacoma Porchfest festival map showing the AM and PM route split"
                class="w-full max-w-md rounded-sm"
            />
            <div class="relative w-full">
                <div class="flex justify-center md:justify-start">
                    <h2
                        class="font-heading text-pf-off-white text-4xl uppercase font-medium self-end text-center md:text-left"
                    >
                        Two Days
                        <br />
                        Two ’Hoods
                    </h2>
                    <img src="/lions-mane.webp" alt="" width="176" height="126" class="w-44 relative md:right-10" />
                </div>
                <p
                    class="font-heading text-pf-cream text-xl uppercase font-medium md:text-left text-center mt-4"
                >
                    Too much goodness for one day. Too much music for one ’hood. Porchfest takes
                    place over 2 days in the central Tacoma area on each side of 6th Ave.
                </p>
            </div>
        </div>
    </section>
    <section class="bg-pf-cream py-2">
        <Carousel class="mx-auto max-w-4xl">
            <FramedPhoto
                src="/photos/home-1.webp"
                alt="Festival-goers in costume at Tacoma Porchfest"
                credit="ohdamn_jam"
            />
            <FramedPhoto
                src="/photos/home-2.webp"
                alt="People dancing at a Tacoma Porchfest show"
                credit="ohdamn_jam"
            />
            <FramedPhoto
                src="/photos/home-3.webp"
                alt="A guitarist performing at Tacoma Porchfest"
                credit="ohdamn_jam"
            />
            <FramedPhoto
                src="/photos/home-4.webp"
                alt="A band performing on a porch at Tacoma Porchfest"
                credit=""
            />
        </Carousel>
    </section>
    <section class="bg-pf-yellow px-4 py-8">
        <div class="mx-auto max-w-4xl">
            <div class="flex flex-wrap justify-center gap-x-2 gap-y-6 sm:gap-8">
                <ShroomLink
                    href="https://forms.gle/5DRSttNLzSgi3pxh8"
                    image="/host-shroom.svg"
                    label="Host a Band"
                    labelClass="text-pf-red"
                />
                <ShroomLink
                    popovertarget="perform-closed"
                    image="/perform-shroom.svg"
                    label="Perform"
                    labelClass="text-pf-cream"
                    badge
                />
                <ShroomLink
                    href="https://forms.gle/HB6YgTvMBpBNP4C27"
                    image="/volunteer-shroom.svg"
                    label="Volunteer"
                    labelClass="text-pf-blue"
                />
            </div>
            <div class="mt-4 text-center font-heading text-pf-navy uppercase">
                <div class="mx-auto max-w-2xl space-y-3 text-base sm:text-lg">
                    <p>
                        Tacoma Porchfest is organized by community members in partnership with
                        Central Neighborhood Council, North End Neighborhood Council, and the Sixth
                        Ave Business District.
                    </p>
                    <p>
                        The festival is made possible with funding from Tacoma Venues & Events and
                        individual donations from festival attendees.
                    </p>
                    <p>Tacoma Porchfest has received Citywide Event Designation.</p>
                </div>
                <h2 class="mt-6 text-4xl font-medium">This machine builds community.</h2>
            </div>
            <div class="mt-4 flex flex-wrap items-center justify-center gap-4">
                <img
                    src="/tacomacreates.webp"
                    alt="Tacoma Creates"
                    class="max-h-28 object-contain"
                />
                <img
                    src="/tacoma_venues_and_events.avif"
                    alt="Tacoma Venues & Events"
                    class="max-h-22 object-contain"
                />
                <img
                    src="/central_neighborhood_council.avif"
                    alt="Central Neighborhood Council"
                    class="max-h-22 object-contain"
                />
                <img
                    src="/north_end_neighborhood_council.avif"
                    alt="North End Neighborhood Council"
                    class="max-h-22 object-contain"
                />
                <img
                    src="/sixth_ave.avif"
                    alt="6th Ave Business District"
                    class="max-h-22 object-contain bg-white rounded-sm p-2"
                />
            </div>
        </div>
    </section>
</Base>

<style>
    /*
     * Hero crop window. As the viewport narrows the image keeps its rendered
     * size and is cropped from the sides (object-fit: cover) until the visible
     * window reaches a square; below that the whole square shrinks.
     * --hero-crop-height is the knob: larger = square is reached at a wider
     * viewport (less side-cropping before shrinking kicks in).
     */
    .hero-crop {
        --hero-w: min(100vw, 56rem);
        --hero-ratio: 1.4762; /* 1674 / 1134, native image aspect ratio */
        --hero-crop-height: 540px;
        width: var(--hero-w);
        height: clamp(
            calc(var(--hero-w) / var(--hero-ratio)),
            var(--hero-crop-height),
            var(--hero-w)
        );
        overflow: hidden;
    }

    /* Arched top edge: both top corners share a 50% horizontal radius so the
     * two corner curves meet at the centre, forming one continuous arc. */
    .red-arc {
        border-top-left-radius: 50% clamp(24px, 5vw, 80px);
        border-top-right-radius: 50% clamp(24px, 5vw, 80px);
    }

    /* Feather the left/right edges of the photo so it dissolves into the gutter.
     * Only applies once the viewport is wider than the photo's max-width (4xl =
     * 56rem); below that the photo is full-bleed and needs no fade. */
    @media (min-width: 56rem) {
        .photo-fade {
            --fade: 12%;
            -webkit-mask-image: linear-gradient(
                to right,
                transparent,
                #000 var(--fade),
                #000 calc(100% - var(--fade)),
                transparent
            );
            mask-image: linear-gradient(
                to right,
                transparent,
                #000 var(--fade),
                #000 calc(100% - var(--fade)),
                transparent
            );
        }
    }
</style>
