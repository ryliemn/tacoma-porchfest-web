---
import Button from "../components/Button.astro";
import Base from "../layouts/Base.astro";
---

<Base title="Host - Tacoma Porchfest">
    <section
        class="flex items-center justify-center bg-pf-red bg-cover bg-center py-8"
        style="background-image: url('/red-texture.webp');"
    >
        <div class="flex flex-col items-center text-center px-4 max-w-3xl">
            <h1 class="font-heading text-pf-brown text-4xl md:text-6xl uppercase">Host</h1>
            <p
                class="mt-4 mb-8 font-body text-pf-cream text-base md:text-lg font-medium leading-relaxed"
            >
                Open your porch to live music and become part of the festival!
            </p>
            <Button href="#signup" text="Sign Up to Host" variant="inverted" />
        </div>
    </section>
    <section class="bg-pf-yellow px-6 py-12 md:px-12 md:py-16">
        <div class="mx-auto max-w-3xl">
            <h2 class="font-heading text-pf-brown text-3xl md:text-5xl uppercase mb-8">
                Frequently Asked Questions
            </h2>
            <p class="font-body text-pf-brown text-sm md:text-base leading-relaxed">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
                incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
                exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
            </p>
        </div>
    </section>
    <section id="signup" class="bg-pf-cream px-6 py-12 md:px-12 md:py-16">
        <div class="mx-auto max-w-3xl text-center">
            <h2 class="font-heading text-pf-red text-3xl md:text-5xl uppercase mb-6">
                Ready to Host?
            </h2>
            <Button href="#" text="Host Sign-Up Form" external class="inline-block px-6 py-1" />
        </div>
    </section>
</Base>
